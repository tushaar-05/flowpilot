      {/* Activity strip */}
      <Card padding="lg">
        <div className="flex items-center justify-between mb-6">
          <CardTitle>Team Pulse</CardTitle>
          <Link to={ROUTES.ACTIVITY} className="text-sm font-extrabold text-primary hover:underline">
