      {children}
      <span
        className={cn(
          'pointer-events-none absolute z-50 whitespace-nowrap rounded-md bg-foreground px-2 py-1 text-xs text-white opacity-0 transition-opacity group-hover:opacity-100',
          positionClasses[position]
        )}
      >
        {content}
      </span>
    </div>
  );
}
